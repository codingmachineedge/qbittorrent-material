{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "qbittorrent-material",
  "version-semver": "5.3.0-material",
  "builtin-baseline": "40a9bd4ccdf5dc14ff76d4ed47d46a226ce84a83",
  "description": "Native dependencies for qBittorrent Material",
  "license": "GPL-3.0-or-later",
  "dependencies": [
    "boost-circular-buffer",
    "boost-headers",
    "boost-multi-index",
    {
      "name": "libgit2",
      "default-features": false,
      "features": [
        "pcre"
      ]
    },
    "libtorrent",
    "openssl",
    "zlib"
  ]
}
